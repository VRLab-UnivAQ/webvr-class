<!DOCTYPE html>
<html>

<head>
    <title>Visualizzazione Immagine 3D</title>
    <script src="https://aframe.io/releases/1.7.0/aframe.min.js"></script>
</head>

<body>
    <a-scene>
        <a-sky src="img/market.jpg" rotation="0 -130 0"></a-sky>
        <a-entity camera look-controls position="0 0 0">
            <a-entity geometry="primitive: sphere; radius: 5000"
                material="shader: flat; src: img/market.jpg"></a-entity>
        </a-entity>
        <a-text value="Stitched Panorama - Marketplace by Luca Biada" color="white" alignment="center" rotation="0 20 0"
            position="-6.5 -2 -3.5" scale="2.5 2.5 2.5"></a-text>
    </a-scene>
</body>

</html>
